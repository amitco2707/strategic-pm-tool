# Streamlit Cloud secrets template.
#
# Locally: you don't need this file — use `.env` instead.
# On Streamlit Cloud: paste these key-value pairs into the app's
# Settings → Secrets UI (NOT by committing this file).
#
# This example is safe to commit; the real secrets.toml is gitignored.

GEMINI_API_KEY = "your_gemini_api_key_here"
GEMINI_MODEL = "gemini-2.5-flash-lite"
